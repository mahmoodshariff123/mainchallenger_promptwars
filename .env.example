# MonsoonReady configuration (copy to .env and fill in)
# GenAI is OpenAI-compatible. Provide ANY of the following:

# Option A — hosted provider (external API):
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Option B — run WITHOUT an external API using a local model server
# (e.g. `ollama serve` with `ollama pull llama3`) and point here:
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3

# Security
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_MAX_AGE=86400

# Storage
DB_PATH=monsoon_ready.db

# Comma-separated origins allowed to call the API from a browser
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
